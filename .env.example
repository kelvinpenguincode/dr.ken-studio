# App runtime (Vercel + local): Supabase → Connect → Transaction pooler (PORT 6543)
# NOT Session mode (5432) — that caps at ~15 clients and takes the site down with EMAXCONNSESSION.
# Required query params for Prisma on serverless:
DATABASE_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=20&sslmode=require"

# Migrations / db push only: Direct connection (or Session if Direct fails on IPv6)
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require"

# Supabase (optional — for future auth/storage integrations)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Admin session signing secret (generate a long random string)
ADMIN_SESSION_SECRET="change-me-to-a-long-random-secret-string"

# Default admin credentials used by `npm run db:seed`
ADMIN_EMAIL="admin@fengjie.local"
ADMIN_PASSWORD="admin123"

# Optional: Google Sheets integration (future)
# GOOGLE_SHEETS_CLIENT_EMAIL=""
# GOOGLE_SHEETS_PRIVATE_KEY=""
# GOOGLE_SHEETS_SPREADSHEET_ID=""

# Apple Push Notifications (iOS app)
# Create a key at developer.apple.com → Certificates, Identifiers & Keys → Keys → Apple Push Notifications service (APNs)
APNS_KEY_ID="YOUR_KEY_ID"
APNS_TEAM_ID="YOUR_TEAM_ID"
APNS_BUNDLE_ID="com.drkenstudio.drkenstudio"
# Paste the .p8 file contents; keep \n for newlines in env vars
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Set to "true" for TestFlight / App Store. Leave unset on Vercel production to auto-enable.
# Use "false" only for local Xcode debug builds (sandbox APNs).
APNS_PRODUCTION="true"
